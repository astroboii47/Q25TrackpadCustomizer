<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="8dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header with title and settings button -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Q25 Trackpad Customizer"
            android:textStyle="bold"
            android:textSize="18sp"
            android:padding="4dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:src="@drawable/baseline_settings_24" />
    </LinearLayout>

    <!-- System default mode -->
    <TextView
        android:id="@+id/tvSystemDefaultLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="System default mode"
        android:textSize="14sp" />

    <Spinner
        android:id="@+id/spinnerSystemDefault"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvGlobalModeInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="This app now uses one global mode and one global quick-toggle cycle. Per-app mode switching has been removed."
        android:textSize="13sp" />

</LinearLayout>
